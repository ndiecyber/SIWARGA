generator zod {
  provider = "prisma-zod-generator"
  output   = "../generated/zod"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Enums
// ==========================================

enum Role {
  user
  admin
}

enum UserType {
  STANDARD
  DEVELOPER
  BANK
}

enum HouseStatus {
  OCCUPIED
  VACANT
}

enum MonthlyDuesStatus {
  PAID
  UNPAID
}

enum PaymentStatus {
  SUCCESS
  FAILED
}

enum ResidentRole {
  MAIN_RESIDENT
  FAMILY_MEMBER
}

enum RelationshipType {
  SELF
  SPOUSE
  CHILD
  PARENT
  SIBLING
  OTHER
}

// ==========================================
// Better-Auth Core Tables
// ==========================================

model User {
  id              String   @id @default(uuid())
  name            String   @db.VarChar(255)
  username        String?  @unique
  displayUsername String?
  email           String?  @unique @db.VarChar(255)
  emailVerified   Boolean  @default(false)
  image           String?  @db.VarChar(500)
  phoneNumber     String   @unique @db.VarChar(20)
  userType        UserType @default(STANDARD)

  role       String?
  banned     Boolean?
  banReason  String?
  banExpires DateTime? @db.Timestamptz(3)

  identificationNumber String? @unique
  kkUrl                String? @db.VarChar(500)
  ktpUrl               String? @db.VarChar(500)

  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @updatedAt @db.Timestamp(3)

  // Relations
  sessions        Session[]
  accounts        Account[]
  housesOwned     House[]   @relation("HouseOwner")
  residentProfile Resident?

  @@map("users")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ==========================================
// Domain Application Tables
// ==========================================

model House {
  id          String      @id @default(uuid())
  houseNumber String      @db.VarChar(50)
  block       String      @db.VarChar(10)
  status      HouseStatus @default(VACANT)
  ownerId     String
  createdAt   DateTime    @default(now()) @db.Timestamp(3)
  updatedAt   DateTime    @updatedAt @db.Timestamp(3)

  owner       User          @relation("HouseOwner", fields: [ownerId], references: [id])
  residents   Resident[]
  monthlyDues MonthlyDues[]

  @@index([ownerId])
}

model Resident {
  id               String           @id @default(uuid())
  userId           String?          @unique // Nullable if minor family members don't have separate system logins
  houseId          String
  parentResidentId String? // Self-referencing FK for tracking family hierarchy under Main Resident
  residentRole     ResidentRole     @default(FAMILY_MEMBER)
  relationship     RelationshipType @default(OTHER)
  createdAt        DateTime         @default(now()) @db.Timestamp(3)
  updatedAt        DateTime         @updatedAt @db.Timestamp(3)

  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  // Self-referencing relations
  mainResident  Resident?  @relation("FamilyHierarchy", fields: [parentResidentId], references: [id], onDelete: Cascade)
  familyMembers Resident[] @relation("FamilyHierarchy")

  @@index([userId])
  @@index([houseId])
  @@index([parentResidentId])
}

model MonthlyDues {
  id        String            @id @default(uuid())
  houseId   String
  amount    Decimal           @db.Decimal(15, 2)
  month     Int
  year      Int
  dueDate   DateTime          @db.Date
  status    MonthlyDuesStatus @default(UNPAID)
  paymentId String?
  createdAt DateTime          @default(now()) @db.Timestamp(3)
  updatedAt DateTime          @updatedAt @db.Timestamp(3)

  house   House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([houseId, month, year])
  @@index([houseId])
  @@index([paymentId])
  @@index([status])
}

model Payment {
  id            String        @id @default(uuid())
  amountPaid    Decimal       @db.Decimal(15, 2)
  paidAt        DateTime      @default(now()) @db.Timestamp(3)
  paymentMethod String        @db.VarChar(50)
  proofUrl      String?       @db.VarChar(500)
  status        PaymentStatus @default(FAILED)
  verifiedBy    String?       @db.VarChar(255)
  createdAt     DateTime      @default(now()) @db.Timestamp(3)
  updatedAt     DateTime      @updatedAt @db.Timestamp(3)

  monthlyDues MonthlyDues[]

  @@index([status])
  @@index([paidAt])
}

model Announcement {
  id          Int       @id @default(autoincrement())
  category    String    @db.VarChar(50)
  title       String    @db.VarChar(255)
  description String    @db.Text
  eventDate   DateTime? @map("tanggal_acara") @db.Date
  status      String    @default("upcoming") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Date
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Date

  @@map("pengumuman")
}
