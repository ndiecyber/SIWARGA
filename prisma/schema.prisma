// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum HouseStatus {
  OCCUPIED
  VACANT
}

enum MonthlyDuesStatus {
  PAID
  UNPAID
}

enum PaymentStatus {
  SUCCESS
  FAILED
}

model User {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(255)
  phone_number String   @unique @db.VarChar(20)
  role         Role
  KK_URL       String   @db.VarChar(500)
  KTP_URL      String   @db.VarChar(500)
  createdAt    DateTime @default(now()) @db.Timestamp(3)
  updatedAt    DateTime @updatedAt @db.Timestamp(3)

  houses_owned House[]         @relation("HouseOwner")
  residences   HouseResident[]
}

model House {
  id           String      @id @default(uuid())
  house_number String      @db.VarChar(50)
  block        String      @db.VarChar(10)
  status       HouseStatus
  owner_id     String?
  createdAt    DateTime    @default(now()) @db.Timestamp(3)
  updatedAt    DateTime    @updatedAt @db.Timestamp(3)

  owner       User?           @relation("HouseOwner", fields: [owner_id], references: [id])
  residents   HouseResident[]
  monthlyDues MonthlyDues[]

  @@index([owner_id])
}

model HouseResident {
  id        String   @id @default(uuid())
  id_user   String
  id_house  String
  createdAt DateTime @default(now()) @db.Timestamp(3)
  updatedAt DateTime @updatedAt @db.Timestamp(3)

  user  User  @relation(fields: [id_user], references: [id], onDelete: Cascade)
  house House @relation(fields: [id_house], references: [id], onDelete: Cascade)

  @@unique([id_user, id_house])
  @@index([id_user])
  @@index([id_house])
}

model MonthlyDues {
  id         String            @id @default(uuid())
  house_id   String
  amount     Decimal           @db.Decimal(15, 2)
  month      Int
  year       Int
  due_date   DateTime          @db.Date
  status     MonthlyDuesStatus
  payment_id String?
  createdAt  DateTime          @default(now()) @db.Timestamp(3)
  updatedAt  DateTime          @updatedAt @db.Timestamp(3)

  house   House    @relation(fields: [house_id], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [payment_id], references: [id])

  @@unique([house_id, month, year])
  @@index([house_id])
  @@index([payment_id])
  @@index([status])
}

model Payment {
  id             String        @id @default(uuid())
  amount_paid    Decimal       @db.Decimal(15, 2)
  paid_at        DateTime      @default(now()) @db.Timestamp(3)
  payment_method String        @db.VarChar(50)
  proof_url      String?       @db.VarChar(500)
  status         PaymentStatus
  verified_by    String?       @db.VarChar(255)
  createdAt      DateTime      @default(now()) @db.Timestamp(3)
  updatedAt      DateTime      @updatedAt @db.Timestamp(3)

  monthlyDues MonthlyDues[]

  @@index([status])
  @@index([paid_at])
}
